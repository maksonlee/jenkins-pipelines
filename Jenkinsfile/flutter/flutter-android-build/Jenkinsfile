@Library('jenkins-shared-lib') _
pipeline {
    agent { label 'ssh-agent-with-docker' }
    options { timestamps() }
    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'WEBHOOK_PROJECT', value: '$.repository.name'],
                [key: 'WEBHOOK_REF', value: '$.ref']
            ],
            causeString: 'GitHub push: $WEBHOOK_PROJECT $WEBHOOK_REF',
            token: 'flutter-android-build',
            printContributedVariables: false,
            printPostContent: false,
            silentResponse: false,
            regexpFilterText: '$WEBHOOK_REF',
            regexpFilterExpression: '^refs/heads/(main|master)$'
        )
    }
    parameters {
        string(name: 'PROJECT', defaultValue: 'taiwan-bus-app', description: 'GitHub repository slug to build')
        string(name: 'BRANCH', defaultValue: '', description: 'Git branch. Empty uses the project default branch.')
        choice(name: 'BUILD_TARGET', choices: ['appbundle-debug', 'appbundle-release', 'apk-debug', 'apk-release'], description: 'Flutter Android build target')
        booleanParam(name: 'PUBLISH_TO_PLAY', defaultValue: false, description: 'Upload release AAB to Google Play')
        choice(name: 'PLAY_TRACK', choices: ['internal', 'closed', 'open', 'production'], description: 'Google Play release track')
        choice(name: 'PLAY_RELEASE_STATUS', choices: ['draft', 'completed', 'inProgress'], description: 'Google Play release status')
        string(name: 'PLAY_ROLLOUT_FRACTION', defaultValue: '', description: 'Required for inProgress staged rollout, for example 0.05')
        booleanParam(name: 'PLAY_REQUIRE_PRODUCTION_APPROVAL', defaultValue: true, description: 'Require manual confirmation before production publish')
    }
    stages {
        stage('Resolve project') {
            steps {
                script {
                    def projectSlug = env.WEBHOOK_PROJECT?.trim() ?: params.PROJECT?.trim()
                    if (!projectSlug) {
                        error 'PROJECT is required'
                    }
                    def webhookBranch = env.WEBHOOK_REF?.trim()?.replaceFirst('^refs/heads/', '')
                    env.PROJECT_REPO = "git@github.com:maksonlee/${projectSlug}.git"
                    env.PROJECT_BRANCH = params.BRANCH?.trim() ?: webhookBranch ?: 'main'
                    env.PROJECT_CREDENTIALS_ID = 'vault-github-ssh'
                    env.FLUTTER_VERSION = '3.44.0'
                    env.FLUTTER_IMAGE = "harbor.maksonlee.com/library/flutter-android-build-env:${env.FLUTTER_VERSION}-fvm"
                    env.FLUTTER_CACHE_ROOT = '/home/administrator/jenkins/flutter-cache'
                    env.ANDROID_CACHE_ROOT = '/home/administrator/jenkins/android-cache'
                    env.ARTIFACTORY_REPO = 'android-snapshots'
                    env.ARTIFACTORY_ORG_PATH = 'com/maksonlee'
                    env.ARTIFACTORY_MODULE = projectSlug
                    env.PLAY_SERVICE_VAULT_PATH = 'secret/jenkins/mobile/shared/play-service'
                }
            }
        }
        stage('Fetch image') {
            steps {
                sh '''#!/bin/bash
set -euo pipefail
docker pull "${FLUTTER_IMAGE}"
docker image inspect "${FLUTTER_IMAGE}" --format 'IMAGE_ID={{.Id}}'
'''
            }
        }
        stage('Fetch code') {
            steps {
                deleteDir()
                dir('source') {
                    git branch: env.PROJECT_BRANCH,
                        credentialsId: env.PROJECT_CREDENTIALS_ID,
                        url: env.PROJECT_REPO
                }
            }
        }
        stage('Resolve Flutter workdir') {
            steps {
                script {
                    def flutterProject = resolveFlutterWorkdir(sourceDir: 'source')
                    env.PROJECT_WORKDIR = flutterProject.workDir
                    env.PROJECT_VERSION_FILE = flutterProject.versionFile
                    echo "Flutter workdir: ${env.PROJECT_WORKDIR}"
                    echo "Version file: ${env.PROJECT_VERSION_FILE}"
                }
            }
        }
        stage('Resolve Android applicationId') {
            steps {
                script {
                    def androidApp = resolveAndroidApplicationId(
                        sourceDir: 'source',
                        workDir: env.PROJECT_WORKDIR
                    )
                    env.PLAY_PACKAGE_NAME = androidApp.playPackageName
                    env.KEYSTORE_VAULT_PATH = androidApp.keystoreVaultPath
                    echo "Android applicationId: ${env.PLAY_PACKAGE_NAME}"
                    echo "applicationId file: ${androidApp.applicationIdFile}"
                    echo "Keystore Vault path: ${env.KEYSTORE_VAULT_PATH}"
                }
            }
        }
        stage('Resolve Google Play metadata') {
            steps {
                script {
                    def projectBase = env.PROJECT_WORKDIR == '.' ? 'source' : "source/${env.PROJECT_WORKDIR}"
                    def releaseNoteCandidates = [
                        "${projectBase}/android/app/src/main/play/release-notes/en-US/${params.PLAY_TRACK}.txt",
                        "${projectBase}/android/app/src/main/play/release-notes/en-US/default.txt"
                    ]
                    def releaseNotesPath = releaseNoteCandidates.find { fileExists(it) }
                    if (releaseNotesPath) {
                        def releaseNotes = readFile(releaseNotesPath).trim()
                        if (!releaseNotes) {
                            error "Google Play release notes are empty: ${releaseNotesPath}"
                        }
                        if (releaseNotes.length() > 500) {
                            error "Google Play release notes exceed 500 characters: ${releaseNotes.length()}"
                        }
                        env.PLAY_RELEASE_NOTES_PATH = releaseNotesPath
                        env.PLAY_RELEASE_NOTES = releaseNotes
                        writeFile file: '.play-release-notes', text: releaseNotes + '\n'
                        echo "PLAY_RELEASE_NOTES_SOURCE=${releaseNotesPath}"
                        echo "PLAY_RELEASE_NOTES<<EOF\n${releaseNotes}\nEOF"
                    } else if (params.PUBLISH_TO_PLAY && params.BUILD_TARGET == 'appbundle-release') {
                        error "Missing Google Play release notes metadata. Expected ${releaseNoteCandidates.join(' or ')}"
                    } else {
                        env.PLAY_RELEASE_NOTES_PATH = ''
                        env.PLAY_RELEASE_NOTES = ''
                        echo "No Google Play release notes metadata found for non-publish build."
                    }
                }
            }
        }
        stage('Prepare release signing') {
            when {
                expression { params.BUILD_TARGET.contains('release') }
            }
            steps {
                script {
                    if (!env.KEYSTORE_VAULT_PATH) {
                        error "No keystoreVaultPath configured for PROJECT=${params.PROJECT}"
                    }
                    withVault([vaultSecrets: [[
                        path: env.KEYSTORE_VAULT_PATH,
                        engineVersion: 2,
                        secretValues: [
                            [envVar: 'UPLOAD_JKS_B64', vaultKey: 'upload_jks_b64'],
                            [envVar: 'STORE_PASSWORD', vaultKey: 'store_password'],
                            [envVar: 'KEY_PASSWORD', vaultKey: 'key_password'],
                            [envVar: 'KEY_ALIAS', vaultKey: 'key_alias']
                        ]
                    ]]]) {
                        sh '''#!/bin/bash
set -euo pipefail
umask 077
signing_dir="source/${PROJECT_WORKDIR}/android"
mkdir -p "${signing_dir}"
: "${UPLOAD_JKS_B64:?ERROR: UPLOAD_JKS_B64 is empty or unset}"
: "${STORE_PASSWORD:?ERROR: STORE_PASSWORD is empty or unset}"
: "${KEY_PASSWORD:?ERROR: KEY_PASSWORD is empty or unset}"
: "${KEY_ALIAS:?ERROR: KEY_ALIAS is empty or unset}"
printf %s "${UPLOAD_JKS_B64}" | sed 's/^data:[^,]*,//' | tr -d '\r\n ' | base64 -d > "${signing_dir}/upload-keystore.jks"
chmod 600 "${signing_dir}/upload-keystore.jks"
cat > "${signing_dir}/key.properties" <<EOF
storePassword=${STORE_PASSWORD}
keyPassword=${KEY_PASSWORD}
keyAlias=${KEY_ALIAS}
storeFile=upload-keystore.jks
EOF
chmod 600 "${signing_dir}/key.properties"
echo "Release signing files prepared. JKS bytes: $(wc -c < "${signing_dir}/upload-keystore.jks")"
'''
                    }
                }
            }
        }
        stage('Build') {
            steps {
                script {
                    def flutterBin = "/home/ubuntu/fvm/versions/${env.FLUTTER_VERSION}/bin/flutter"
                    def commandByTarget = [
                        'appbundle-debug': "${flutterBin} pub get && ${flutterBin} build appbundle --debug --no-pub --no-android-gradle-daemon",
                        'appbundle-release': "${flutterBin} pub get && ${flutterBin} build appbundle --release --no-pub --no-android-gradle-daemon",
                        'apk-debug': "${flutterBin} pub get && ${flutterBin} build apk --debug --no-pub --no-android-gradle-daemon",
                        'apk-release': "${flutterBin} pub get && ${flutterBin} build apk --release --no-pub --no-android-gradle-daemon"
                    ]
                    def artifactBase = env.PROJECT_WORKDIR == '.' ? 'source' : 'source/' + env.PROJECT_WORKDIR
                    def artifactByTarget = [
                        'appbundle-debug': artifactBase + '/build/app/outputs/bundle/debug/*.aab',
                        'appbundle-release': artifactBase + '/build/app/outputs/bundle/release/*.aab',
                        'apk-debug': artifactBase + '/build/app/outputs/flutter-apk/*.apk',
                        'apk-release': artifactBase + '/build/app/outputs/flutter-apk/*.apk'
                    ]
                    env.FLUTTER_BUILD_COMMAND = commandByTarget[params.BUILD_TARGET]
                    env.FLUTTER_ARTIFACTS = artifactByTarget[params.BUILD_TARGET]
                    if (!env.FLUTTER_BUILD_COMMAND) error "Unknown BUILD_TARGET: ${params.BUILD_TARGET}"
                }
                sh '''#!/bin/bash
set -euo pipefail
uid=$(id -u)
gid=$(id -g)
flutter_cache_root="${FLUTTER_CACHE_ROOT}"
android_cache_root="${ANDROID_CACHE_ROOT}"
android_cache="${android_cache_root}/flutter-android-sdk"
fvm_cache="${flutter_cache_root}/fvm"
gradle_cache="${android_cache_root}/gradle"
pub_cache="${flutter_cache_root}/pub-cache"
mkdir -p "${android_cache}" "${gradle_cache}" "${pub_cache}" "${fvm_cache}"

if [ ! -d "${android_cache}/cmdline-tools/latest" ]; then
  echo "Seeding Android command-line tools into ${android_cache}"
  seed_container=$(docker create "${FLUTTER_IMAGE}")
  trap 'docker rm -f "${seed_container}" >/dev/null 2>&1 || true' EXIT
  docker cp "${seed_container}:/home/ubuntu/Android/cmdline-tools" "${android_cache}/"
  docker rm "${seed_container}" >/dev/null
  trap - EXIT
fi

mkdir -p \
  "${android_cache}/platforms" \
  "${android_cache}/build-tools" \
  "${android_cache}/platform-tools" \
  "${android_cache}/ndk" \
  "${android_cache}/cmake" \
  "${android_cache}/licenses"

echo "FLUTTER_CACHE_ROOT=${flutter_cache_root}"
echo "ANDROID_CACHE_ROOT=${android_cache_root}"
echo "FLUTTER_CACHE_SIZE_BEFORE=$(du -sh "${flutter_cache_root}" 2>/dev/null | cut -f1)"
echo "ANDROID_CACHE_SIZE_BEFORE=$(du -sh "${android_cache_root}" 2>/dev/null | cut -f1)"
start=$(date +%s)

docker run --rm \
  -u ${uid}:${gid} \
  -e HOME=/home/ubuntu \
  -e ANDROID_HOME=/home/ubuntu/Android \
  -e ANDROID_SDK_ROOT=/home/ubuntu/Android \
  -e FVM_CACHE_PATH=/home/ubuntu/fvm \
  -e PUB_CACHE=/home/ubuntu/pub-cache \
  -v "${android_cache}:/home/ubuntu/Android" \
  -v "${fvm_cache}:/home/ubuntu/fvm" \
  -v "${gradle_cache}:/home/ubuntu/.gradle" \
  -v "${pub_cache}:/home/ubuntu/pub-cache" \
  -v "$PWD/source:/workspace" \
  -w "/workspace/${PROJECT_WORKDIR}" \
  "${FLUTTER_IMAGE}" \
  bash -lc "yes | sdkmanager --licenses && fvm install ${FLUTTER_VERSION} && /home/ubuntu/fvm/versions/${FLUTTER_VERSION}/bin/flutter config --no-analytics && /home/ubuntu/fvm/versions/${FLUTTER_VERSION}/bin/flutter --version && ${FLUTTER_BUILD_COMMAND}"

end=$(date +%s)
echo "TOTAL_SECONDS=$((end-start))"
echo "FLUTTER_CACHE_SIZE_AFTER=$(du -sh "${flutter_cache_root}" 2>/dev/null | cut -f1)"
echo "ANDROID_CACHE_SIZE_AFTER=$(du -sh "${android_cache_root}" 2>/dev/null | cut -f1)"
for d in "${flutter_cache_root}"/* "${android_cache_root}"/*; do
  if [ -d "$d" ]; then du -sh "$d"; fi
done | sort -h || true
ls -lh ${FLUTTER_ARTIFACTS}
'''
            }
        }
        stage('Archive artifacts') {
            steps {
                archiveArtifacts artifacts: env.FLUTTER_ARTIFACTS, fingerprint: true
            }
        }
        stage('Upload to Artifactory') {
            steps {
                script {
                    def versionText = readFile("source/${env.PROJECT_VERSION_FILE}")
                    def baseRev = null
                    versionText.readLines().each { line ->
                        def trimmed = line.trim()
                        if (baseRev == null && trimmed.startsWith('version:')) {
                            baseRev = trimmed.substring('version:'.length()).trim().split('\\+')[0]
                        }
                    }
                    if (!baseRev) {
                        error "Cannot find version in source/${env.PROJECT_VERSION_FILE}"
                    }

                    def extByTarget = [
                        'appbundle-debug': 'aab',
                        'appbundle-release': 'aab',
                        'apk-debug': 'apk',
                        'apk-release': 'apk'
                    ]
                    def ext = extByTarget[params.BUILD_TARGET]
                    if (!ext) error "Unknown BUILD_TARGET: ${params.BUILD_TARGET}"

                    def timestamp = new Date().format('yyyyMMdd.HHmmss', TimeZone.getTimeZone('UTC'))
                    def fileItegRev = "${timestamp}-${env.BUILD_NUMBER}"
                    def targetBase = "${env.ARTIFACTORY_REPO}/${env.ARTIFACTORY_ORG_PATH}/${env.ARTIFACTORY_MODULE}/${baseRev}-SNAPSHOT"
                    def targetFile = "${env.ARTIFACTORY_MODULE}-${baseRev}-${fileItegRev}.${ext}"
                    def spec = """{
  "files": [
    {
      "pattern": "${env.FLUTTER_ARTIFACTS}",
      "target": "${targetBase}/${targetFile}",
      "flat": true
    }
  ]
}"""

                    echo "Uploading artifacts to: ${targetBase}"
                    echo "Artifactory file: ${targetFile}"
                    rtUpload(serverId: 'artifactory', spec: spec, failNoOp: true)
                }
            }
        }
        stage('Approve production publish?') {
            when {
                expression {
                    params.PUBLISH_TO_PLAY &&
                        params.BUILD_TARGET == 'appbundle-release' &&
                        params.PLAY_TRACK == 'production' &&
                        params.PLAY_REQUIRE_PRODUCTION_APPROVAL
                }
            }
            steps {
                input message: "Publish ${env.PLAY_PACKAGE_NAME} to Google Play production as ${params.PLAY_RELEASE_STATUS}? ${env.PLAY_RELEASE_NOTES}"
            }
        }
        stage('Upload to Google Play') {
            when {
                expression { params.PUBLISH_TO_PLAY && params.BUILD_TARGET == 'appbundle-release' }
            }
            steps {
                script {
                    if (!env.PLAY_SERVICE_VAULT_PATH) {
                        error "No playServiceVaultPath configured for PROJECT=${params.PROJECT}"
                    }
                    if (!env.PLAY_PACKAGE_NAME) {
                        error "No packageName configured for PROJECT=${params.PROJECT}"
                    }
                    if (!env.PLAY_RELEASE_NOTES?.trim()) {
                        error "No Google Play release notes loaded for PROJECT=${params.PROJECT}"
                    }
                    withVault([vaultSecrets: [[
                        path: env.PLAY_SERVICE_VAULT_PATH,
                        engineVersion: 2,
                        secretValues: [[envVar: 'PLAY_SERVICE_JSON_B64', vaultKey: 'json_b64']]
                    ]]]) {
                        sh '''#!/bin/bash
set -euo pipefail
umask 077
: "${PLAY_SERVICE_JSON_B64:?ERROR: PLAY_SERVICE_JSON_B64 is empty or unset}"
play_json="$PWD/play-service.json"
trap 'rm -f "$play_json"' EXIT
aab_path=$(ls ${FLUTTER_ARTIFACTS} | head -n 1)
release_notes_path="$PWD/.play-release-notes"
if [ ! -s "$release_notes_path" ]; then
  echo "Missing Google Play release notes file: $release_notes_path" >&2
  exit 1
fi
printf %s "${PLAY_SERVICE_JSON_B64}" | sed 's/^data:[^,]*,//' | tr -d '\r\n ' | base64 -d > "$play_json"
python3 - "$play_json" "$aab_path" "$PLAY_PACKAGE_NAME" "$PLAY_TRACK" "$PLAY_RELEASE_STATUS" "${PLAY_ROLLOUT_FRACTION:-}" "$release_notes_path" <<'PY'
import base64
import json
import os
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request

service_json, aab_path, package_name, track, release_status, rollout_fraction, release_notes_path = sys.argv[1:]
with open(service_json, 'r', encoding='utf-8') as f:
    svc = json.load(f)
with open(release_notes_path, 'r', encoding='utf-8') as f:
    release_notes = f.read().strip()
if not release_notes:
    raise SystemExit('Google Play release notes are required')
if len(release_notes) > 500:
    raise SystemExit(f'Google Play release notes exceed 500 characters: {len(release_notes)}')

def b64url(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).rstrip(b'=').decode('ascii')

now = int(time.time())
header = {'alg': 'RS256', 'typ': 'JWT'}
payload = {
    'iss': svc['client_email'],
    'scope': 'https://www.googleapis.com/auth/androidpublisher',
    'aud': 'https://oauth2.googleapis.com/token',
    'iat': now,
    'exp': now + 3600,
}
signing_input = f"{b64url(json.dumps(header, separators=(',', ':')).encode())}.{b64url(json.dumps(payload, separators=(',', ':')).encode())}"
with tempfile.NamedTemporaryFile('w', delete=False) as key_file:
    key_file.write(svc['private_key'])
    key_path = key_file.name
try:
    signature = subprocess.check_output(['openssl', 'dgst', '-sha256', '-sign', key_path], input=signing_input.encode('ascii'))
finally:
    try:
        os.remove(key_path)
    except OSError:
        pass
assertion = signing_input + '.' + b64url(signature)

def request_json(method, url, token=None, data=None, content_type='application/json'):
    body = None
    headers = {}
    if token:
        headers['Authorization'] = f'Bearer {token}'
    if data is not None:
        if isinstance(data, (dict, list)):
            body = json.dumps(data).encode('utf-8')
            headers['Content-Type'] = content_type
        else:
            body = data
            headers['Content-Type'] = content_type
    req = urllib.request.Request(url, data=body, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            raw = resp.read().decode('utf-8')
            return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        err = e.read().decode('utf-8', errors='replace')
        raise SystemExit(f'HTTP {e.code} {method} {url}\\n{err}')

token_resp = request_json('POST', 'https://oauth2.googleapis.com/token', data=urllib.parse.urlencode({
    'grant_type': 'urn:ietf:params:oauth:grant-type:jwt-bearer',
    'assertion': assertion,
}).encode('utf-8'), content_type='application/x-www-form-urlencoded')
token = token_resp['access_token']
base = f'https://androidpublisher.googleapis.com/androidpublisher/v3/applications/{urllib.parse.quote(package_name, safe="")}'
edit = request_json('POST', base + '/edits', token=token)
edit_id = edit['id']
print(f'Created Google Play edit: {edit_id}')
with open(aab_path, 'rb') as f:
    bundle = f.read()
upload_url = f'https://androidpublisher.googleapis.com/upload/androidpublisher/v3/applications/{urllib.parse.quote(package_name, safe="")}/edits/{edit_id}/bundles?uploadType=media'
bundle_resp = request_json('POST', upload_url, token=token, data=bundle, content_type='application/octet-stream')
version_code = str(bundle_resp['versionCode'])
print(f'Uploaded bundle versionCode: {version_code}')
release = {
    'versionCodes': [version_code],
    'status': release_status,
    'releaseNotes': [{
        'language': 'en-US',
        'text': release_notes,
    }],
}
if release_status == 'inProgress':
    if not rollout_fraction.strip():
        raise SystemExit('PLAY_ROLLOUT_FRACTION is required when PLAY_RELEASE_STATUS=inProgress')
    try:
        user_fraction = float(rollout_fraction)
    except ValueError:
        raise SystemExit(f'Invalid PLAY_ROLLOUT_FRACTION: {rollout_fraction!r}')
    if not 0 < user_fraction < 1:
        raise SystemExit('PLAY_ROLLOUT_FRACTION must be greater than 0 and less than 1')
    release['userFraction'] = user_fraction
elif rollout_fraction.strip():
    print(f'Ignoring PLAY_ROLLOUT_FRACTION because release status is {release_status}.')
track_body = {
    'track': track,
    'releases': [release]
}
request_json('PUT', base + f'/edits/{edit_id}/tracks/{urllib.parse.quote(track, safe="")}', token=token, data=track_body)
request_json('POST', base + f'/edits/{edit_id}:commit', token=token)
print(f'Committed Google Play {track} release as {release_status}.')
PY
rm -f "$play_json"
'''
                    }
                }
            }
        }
    }
    post {
        always {
            cleanWs()
        }
    }
}
